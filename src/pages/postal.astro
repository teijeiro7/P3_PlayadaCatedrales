---
import Layout from "../layouts/Layout.astro";

const imagenesPostal = [
  { id: "catedrales", src: "/images/tarjeta-catedrales.jpg", alt: "Arcos monumentales de la Playa de las Catedrales", titulo: "Catedral Natural" },
  { id: "atardecer", src: "/images/tarjeta-atardecer.jpg", alt: "Atardecer dorado sobre los acantilados", titulo: "Atardecer Magico" },
  { id: "arena", src: "/images/tarjeta-arena.jpg", alt: "Arena dorada y texturas de la orilla", titulo: "Tesoros de la Arena" },
  { id: "paisaje", src: "/images/galeria-paisaje-01.jpg", alt: "Vista panoramica de la playa", titulo: "Panoramica Monumental" },
  { id: "arcos", src: "/images/galeria-arcos-01.jpg", alt: "Arcos naturales de piedra pizarra", titulo: "Arcos Centrales" },
  { id: "mareas", src: "/images/galeria-mareas-01.jpg", alt: "Formaciones rocosas en marea baja", titulo: "Secretos de la Marea" },
];
---

<Layout
  title="Enviar Postal"
  description="Envia una postal digital de la Playa de las Catedrales a tus seres queridos. Elige una imagen y personaliza tu mensaje."
  variant="home"
>
  <section class="hero-parallax" aria-labelledby="hero-title">
    <div class="hero-parallax-bg postal-hero" aria-hidden="true"></div>
    <div class="hero-parallax-overlay"></div>
    <div class="hero-parallax-content">
      <span class="hero-eyebrow">COMPARTE LA MAGIA</span>
      <h1 id="hero-title" class="hero-title">
        Envia una Postal<br />desde Galicia
      </h1>
      <p class="hero-subtitle">
        Elige una imagen, escribe tu mensaje y comparte la belleza de la Praia
        das Catedrais con quien mas quieres.
      </p>
      <div class="hero-scroll-hint" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path
            d="M12 5v14m0 0l-6-6m6 6l6-6"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
      </div>
    </div>
  </section>

  <section class="postal-section" aria-labelledby="postal-title">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">POSTAL DIGITAL</span>
        <h2 id="postal-title" class="section-title">Crea tu Postal</h2>
        <p class="section-subtitle">
          Selecciona una imagen, rellena los datos y envia una postal unica a tu
          destinatario.
        </p>
      </div>

      <div class="postal-grid">
        <!-- Formulario -->
        <div class="form-panel reveal">
          <form
            id="postal-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            aria-label="Formulario para crear y enviar una postal digital"
          >
            <!-- Web3Forms config -->
            <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY" />
            <input type="hidden" name="subject" value="¡Te han enviado una postal de la Playa de las Catedrales!" />
            <input type="hidden" name="from_name" value="Praia das Catedrais" />
            <input type="checkbox" name="botcheck" class="hidden" aria-hidden="true" />

            <!-- Selector de imagen -->
            <fieldset class="imagen-selector">
              <legend>1. Elige una imagen para tu postal</legend>
              <div class="imagenes-grid" role="radiogroup" aria-label="Seleccion de imagen para la postal">
                {
                  imagenesPostal.map((img) => (
                    <label class="imagen-option">
                      <input
                        type="radio"
                        name="imagen_postal"
                        value={img.id}
                        data-src={img.src}
                        data-titulo={img.titulo}
                        required
                        aria-label={img.alt}
                      />
                      <div class="imagen-card">
                        <img src={img.src} alt={img.alt} loading="lazy" />
                        <span class="imagen-titulo">{img.titulo}</span>
                      </div>
                    </label>
                  ))
                }
              </div>
            </fieldset>

            <!-- Datos del emisor -->
            <fieldset class="datos-fieldset">
              <legend>2. Tus datos</legend>
              <div class="form-row">
                <div class="form-group">
                  <label for="nombre_emisor">
                    Tu nombre
                    <span class="required" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="text"
                    id="nombre_emisor"
                    name="nombre_emisor"
                    required
                    aria-required="true"
                    autocomplete="name"
                    placeholder="Tu nombre completo"
                  />
                </div>
                <div class="form-group">
                  <label for="email_emisor">
                    Tu correo
                    <span class="required" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="email"
                    id="email_emisor"
                    name="email_emisor"
                    required
                    aria-required="true"
                    autocomplete="email"
                    placeholder="tu@email.com"
                  />
                </div>
              </div>
            </fieldset>

            <!-- Datos del destinatario -->
            <fieldset class="datos-fieldset">
              <legend>3. Datos del destinatario</legend>
              <div class="form-row">
                <div class="form-group">
                  <label for="nombre_destinatario">
                    Nombre del destinatario
                    <span class="required" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="text"
                    id="nombre_destinatario"
                    name="nombre_destinatario"
                    required
                    aria-required="true"
                    placeholder="Nombre de quien recibe"
                  />
                </div>
                <div class="form-group">
                  <label for="email_destinatario">
                    Correo del destinatario
                    <span class="required" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="email"
                    id="email_destinatario"
                    name="email_destinatario"
                    required
                    aria-required="true"
                    placeholder="destinatario@email.com"
                  />
                </div>
              </div>
            </fieldset>

            <!-- Mensaje -->
            <fieldset class="datos-fieldset">
              <legend>4. Tu mensaje</legend>
              <div class="form-group">
                <label for="mensaje">
                  Mensaje personal
                  <span class="required" aria-hidden="true">*</span>
                </label>
                <textarea
                  id="mensaje"
                  name="mensaje"
                  rows="4"
                  maxlength="300"
                  required
                  aria-required="true"
                  aria-describedby="contador-caracteres"
                  placeholder="Escribe un mensaje especial para tu postal..."
                ></textarea>
                <p id="contador-caracteres" class="contador" aria-live="polite"
                >0 / 300 caracteres</p>
              </div>
            </fieldset>

            <!-- Template de postal (se envia como campos ocultos) -->
            <input type="hidden" name="lugar" value="Playa de las Catedrales (Praia das Catedrais)" />
            <input type="hidden" name="direccion" value="San Miguel de Reinante, Ribadeo, Lugo, Galicia, Espana" />
            <input type="hidden" name="template" value="postal_catedrales" />

            <button type="submit" class="btn-enviar"
              >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M22 2L11 13" />
                <path d="M22 2l-7 20-4-9-9-4 20-7z" />
              </svg>
              Enviar Postal
            </button>
          </form>

          <!-- Mensaje de exito (oculto inicialmente) -->
          <div id="mensaje-exito" class="mensaje-exito" role="alert" aria-live="polite" hidden>
            <div class="exito-icono">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14" />
                <polyline points="22 4 12 14.01 9 11.01" />
              </svg>
            </div>
            <h3>¡Postal Enviada!</h3>
            <p>Tu postal ha sido enviada correctamente. El destinatario la recibira en su correo electronico.</p>
            <button type="button" class="btn-secondary" onclick="resetForm()"
              >Enviar otra postal</button>
          </div>
        </div>

        <!-- Previsualizacion de la postal -->
        <div class="preview-panel reveal">
          <div class="preview-card" id="preview-card">
            <div class="preview-marca">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              <span>Praia das Catedrais</span>
            </div>

            <div class="preview-imagen">
              <img
                id="preview-img"
                src="/images/tarjeta-catedrales.jpg"
                alt="Previsualizacion de la postal"
              />
              <div class="preview-overlay"></div>
            </div>

            <div class="preview-contenido">
              <div class="preview-lugar">
                <h3 id="preview-lugar-nombre">Playa de las Catedrales</h3>
                <p id="preview-lugar-direccion"
                  >San Miguel de Reinante, Ribadeo, Lugo</p
                >
              </div>

              <div class="preview-mensaje">
                <div class="preview-remite">
                  <span>De:</span>
                  <strong id="preview-emisor">Tu nombre</strong>
                </div>
                <div class="preview-para">
                  <span>Para:</span>
                  <strong id="preview-destinatario">Nombre del destinatario</strong>
                </div>
                <div class="preview-texto" id="preview-mensaje"
                  >Tu mensaje aparecera aqui...</div
                >
              </div>

              <div class="preview-footer">
                <div class="preview-sello">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <path d="M2 12h20" />
                    <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z" />
                  </svg>
                  <span>Galicia</span>
                </div>
                <span class="preview-anio">2025</span>
              </div>
            </div>
          </div>

          <p class="preview-leyenda">
            Asi se vera tu postal cuando el destinatario la reciba.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="cta-title">
    <div class="cta-content reveal">
      <h2 id="cta-title">¿Ya has visitado la playa?</h2>
      <p>Comparte tu experiencia y descubre mas sobre este monumento natural.</p>
      <div class="cta-buttons">
        <a href="/galeria" class="btn-secondary">Ver Galeria</a>
        <a href="/historia" class="btn-secondary">Conocer Historia</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Scroll animations
  const observerOptions = {
    root: null,
    rootMargin: "0px",
    threshold: 0.1,
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("visible");
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));

  // Preview update logic
  const form = document.getElementById("postal-form");
  const previewImg = document.getElementById("preview-img");
  const previewEmisor = document.getElementById("preview-emisor");
  const previewDestinatario = document.getElementById("preview-destinatario");
  const previewMensaje = document.getElementById("preview-mensaje");
  const contador = document.getElementById("contador-caracteres");
  const mensajeTextarea = document.getElementById("mensaje");

  // Update image preview
  document.querySelectorAll('input[name="imagen_postal"]').forEach((radio) => {
    radio.addEventListener("change", () => {
      const src = radio.getAttribute("data-src");
      const titulo = radio.getAttribute("data-titulo");
      previewImg.src = src;
      previewImg.alt = `Postal: ${titulo}`;
    });
  });

  // Update text preview
  document
    .getElementById("nombre_emisor")
    .addEventListener("input", (e) => {
      previewEmisor.textContent = e.target.value || "Tu nombre";
    });

  document
    .getElementById("nombre_destinatario")
    .addEventListener("input", (e) => {
      previewDestinatario.textContent =
        e.target.value || "Nombre del destinatario";
    });

  mensajeTextarea.addEventListener("input", (e) => {
    const texto = e.target.value;
    previewMensaje.textContent = texto || "Tu mensaje aparecera aqui...";
    contador.textContent = `${texto.length} / 300 caracteres`;
  });

  // Form submission
  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = `
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin">
        <circle cx="12" cy="12" r="10" stroke-dasharray="60" stroke-dashoffset="10" />
      </svg>
      Enviando...
    `;

    try {
      const formData = new FormData(form);
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: formData,
      });

      const result = await response.json();

      if (result.success) {
        form.style.display = "none";
        document.getElementById("mensaje-exito").hidden = false;
        document.getElementById("mensaje-exito").classList.add("visible");
      } else {
        throw new Error(result.message || "Error al enviar");
      }
    } catch (error) {
      alert("Error al enviar la postal. Por favor, intentalo de nuevo.");
      console.error(error);
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  });

  // Reset form
  function resetForm() {
    form.reset();
    form.style.display = "block";
    document.getElementById("mensaje-exito").hidden = true;
    document.getElementById("mensaje-exito").classList.remove("visible");

    // Reset preview
    previewImg.src = "/images/tarjeta-catedrales.jpg";
    previewEmisor.textContent = "Tu nombre";
    previewDestinatario.textContent = "Nombre del destinatario";
    previewMensaje.textContent = "Tu mensaje aparecera aqui...";
    contador.textContent = "0 / 300 caracteres";
  }

  // Expose resetForm globally
  window.resetForm = resetForm;
</script>

<style>
  /* Hero Parallax */
  .hero-parallax {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--color-bg);
  }

  .hero-parallax-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    will-change: transform;
  }

  .postal-hero {
    background-image: url("/images/galeria-atardecer-01.jpg");
  }

  .hero-parallax-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 35, 66, 0.5) 0%,
      rgba(10, 35, 66, 0.7) 50%,
      rgba(10, 35, 66, 0.9) 100%
    );
  }

  .hero-parallax-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;
    padding: 2rem;
    max-width: 900px;
  }

  .hero-eyebrow {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    text-wrap: balance;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.35rem);
    line-height: 1.6;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  .hero-scroll-hint {
    margin-top: 3rem;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(10px);
    }
  }

  /* Postal Section */
  .postal-section {
    padding: 6rem 1rem;
    background: var(--color-bg);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text);
    line-height: 1.2;
  }

  .section-subtitle {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .postal-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Form Panel */
  .form-panel {
    background: var(--color-surface);
    border-radius: 20px;
    padding: 2.5rem;
    border: 1px solid rgba(0, 188, 212, 0.1);
  }

  .imagen-selector {
    border: none;
    padding: 0;
    margin: 0 0 2rem 0;
  }

  .imagen-selector legend {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 1rem;
    padding: 0;
  }

  .imagenes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .imagen-option {
    cursor: pointer;
    position: relative;
  }

  .imagen-option input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .imagen-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    border: 3px solid transparent;
    transition: border-color 0.2s, transform 0.2s;
  }

  .imagen-card img {
    width: 100%;
    height: 100px;
    object-fit: cover;
    display: block;
  }

  .imagen-titulo {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.5rem;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    color: white;
    font-size: 0.75rem;
    font-weight: 500;
    text-align: center;
  }

  .imagen-option input:checked + .imagen-card {
    border-color: var(--color-accent);
    transform: scale(1.05);
  }

  .imagen-option input:focus + .imagen-card {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }

  .datos-fieldset {
    border: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
  }

  .datos-fieldset legend {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 1rem;
    padding: 0;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  .form-group label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--color-text);
    font-size: 0.9rem;
  }

  .required {
    color: #e74c3c;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.875rem;
    border: 2px solid rgba(0, 188, 212, 0.2);
    border-radius: 10px;
    font-size: 1rem;
    font-family: inherit;
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(0, 188, 212, 0.1);
  }

  .form-group input:user-invalid,
  .form-group textarea:user-invalid {
    border-color: #e74c3c;
  }

  .contador {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    text-align: right;
    margin-top: 0.25rem;
  }

  .hidden {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .btn-enviar {
    width: 100%;
    padding: 1rem;
    background: linear-gradient(135deg, var(--color-accent), var(--color-primary));
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-enviar:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0, 188, 212, 0.3);
  }

  .btn-enviar:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .spin {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  /* Success Message */
  .mensaje-exito {
    text-align: center;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, rgba(46, 204, 113, 0.1), rgba(39, 174, 96, 0.1));
    border-radius: 20px;
    border: 2px solid rgba(46, 204, 113, 0.3);
  }

  .mensaje-exito.hidden {
    display: none;
  }

  .exito-icono {
    width: 80px;
    height: 80px;
    margin: 0 auto 1.5rem;
    background: linear-gradient(135deg, #2ecc71, #27ae60);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .mensaje-exito h3 {
    font-size: 1.5rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .mensaje-exito p {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }

  /* Preview Panel */
  .preview-panel {
    position: sticky;
    top: 100px;
  }

  .preview-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
    transform: rotate(-2deg);
    transition: transform 0.3s;
  }

  .preview-card:hover {
    transform: rotate(0deg) scale(1.02);
  }

  .preview-marca {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: white;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .preview-imagen {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .preview-imagen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
