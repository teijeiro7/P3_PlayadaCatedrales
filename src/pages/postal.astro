---
import Layout from "../layouts/Layout.astro";

const imagenesPostal = [
  { id: "catedrales", src: "/images/seccion-arcos.jpg", alt: "Arcos monumentales de la Playa de las Catedrales", titulo: "Catedral Natural" },
  { id: "atardecer", src: "/images/galeria-atardecer.jpg", alt: "Atardecer dorado sobre los acantilados", titulo: "Atardecer Magico" },
  { id: "arena", src: "/images/galeria-percebes.jpg", alt: "Detalles y texturas de la playa", titulo: "Tesoros de la Arena" },
  { id: "paisaje", src: "/images/galeria-panoramica.jpg", alt: "Vista panoramica de la playa", titulo: "Panoramica" },
  { id: "arcos", src: "/images/galeria-visitantes.jpg", alt: "Arcos centrales de la playa", titulo: "Arcos Centrales" },
  { id: "mareas", src: "/images/galeria-mareas.jpg", alt: "Formaciones en marea baja", titulo: "Mareas" },
];
---

<Layout
  title="Enviar Postal"
  description="Envia una postal digital de la Playa de las Catedrales a tus seres queridos."
>
  <div class="postal-page">
    <!-- Hero simple -->
    <section class="postal-hero" aria-labelledby="hero-title">
      <div class="postal-hero-content">
        <span class="hero-eyebrow">COMPARTE LA MAGIA</span>
        <h1 id="hero-title">Envia una Postal desde Galicia</h1>
        <p>Elige una imagen, escribe tu mensaje y comparte la belleza de la Praia das Catedrais.</p>
      </div>
    </section>

    <!-- Formulario y preview -->
    <section class="postal-main" aria-labelledby="form-title">
      <div class="postal-container">
        <div class="section-header">
          <span class="section-label">POSTAL DIGITAL</span>
          <h2 id="form-title">Crea tu Postal</h2>
        </div>

        <div class="postal-grid">
          <!-- Formulario -->
          <div class="form-panel">
            <form
              id="postal-form"
              action="https://api.web3forms.com/submit"
              method="POST"
              aria-label="Formulario para enviar una postal digital"
            >
              <input type="hidden" name="access_key" value="57962e2e-32c0-4bce-9459-c3e6d8af94ba" />
              <input type="hidden" name="subject" value="Te han enviado una postal de la Playa de las Catedrales!" />
              <input type="hidden" name="from_name" value="Praia das Catedrais" />
              <input type="checkbox" name="botcheck" style="display: none" tabindex="-1" />

              <fieldset class="form-section">
                <legend>1. Elige una imagen</legend>
                <div class="imagenes-grid">
                  {
                    imagenesPostal.map((img) => (
                      <label class="imagen-option">
                        <input
                          type="radio"
                          name="imagen_postal"
                          value={img.id}
                          data-src={img.src}
                          data-titulo={img.titulo}
                          required
                        />
                        <div class="imagen-card">
                          <img src={img.src} alt={img.alt} loading="lazy" width="200" height="150" />
                          <span class="imagen-titulo">{img.titulo}</span>
                        </div>
                      </label>
                    ))
                  }
                </div>
              </fieldset>

              <fieldset class="form-section">
                <legend>2. Tus datos</legend>
                <div class="form-row">
                  <div class="form-group">
                    <label for="nombre_emisor">Tu nombre *</label>
                    <input type="text" id="nombre_emisor" name="nombre_emisor" required placeholder="Tu nombre" autocomplete="name" />
                  </div>
                  <div class="form-group">
                    <label for="email_emisor">Tu correo *</label>
                    <input type="email" id="email_emisor" name="email_emisor" required placeholder="tu@email.com" autocomplete="email" />
                  </div>
                </div>
              </fieldset>

              <fieldset class="form-section">
                <legend>3. Datos del destinatario</legend>
                <div class="form-row">
                  <div class="form-group">
                    <label for="nombre_destinatario">Nombre *</label>
                    <input type="text" id="nombre_destinatario" name="nombre_destinatario" required placeholder="Nombre del destinatario" />
                  </div>
                  <div class="form-group">
                    <label for="email_destinatario">Correo *</label>
                    <input type="email" id="email_destinatario" name="email_destinatario" required placeholder="destinatario@email.com" />
                  </div>
                </div>
              </fieldset>

              <fieldset class="form-section">
                <legend>4. Tu mensaje</legend>
                <div class="form-group">
                  <label for="mensaje">Mensaje *</label>
                  <textarea
                    id="mensaje"
                    name="mensaje"
                    rows="4"
                    maxlength="300"
                    required
                    placeholder="Escribe un mensaje especial..."
                  ></textarea>
                  <p class="contador" aria-live="polite"><span id="contador">0</span> / 300 caracteres</p>
                </div>
              </fieldset>

              <input type="hidden" name="lugar" value="Playa de las Catedrales" />
              <input type="hidden" name="direccion" value="Ribadeo, Lugo, Galicia" />

              <button type="submit" class="btn-enviar"
                >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 2L11 13" />
                  <path d="M22 2l-7 20-4-9-9-4 20-7z" />
                </svg>
                Enviar Postal
              </button>
            </form>

            <div id="mensaje-exito" class="mensaje-exito" hidden>
              <div class="exito-icon">✓</div>
              <h3>Postal Enviada!</h3>
              <p>Tu postal ha sido enviada correctamente.</p>
              <button type="button" class="btn-secondary" onclick="window.resetForm()">Enviar otra</button>
            </div>
          </div>

          <!-- Preview -->
          <div class="preview-panel">
            <div class="preview-card" id="preview-card">
              <div class="preview-header">
                <span class="preview-logo">Praia das Catedrais</span>
              </div>

              <div class="preview-image">
                <img id="preview-img" src="/images/seccion-arcos.jpg" alt="Postal" width="400" height="300" />
              </div>

              <div class="preview-body">
                <div class="preview-location">
                  <h3>Playa de las Catedrales</h3>
                  <p>Ribadeo, Lugo, Galicia</p>
                </div>

                <div class="preview-message">
                  <div class="preview-from">
                    <span>De:</span> <strong id="preview-emisor">Tu nombre</strong>
                  </div>
                  <div class="preview-to">
                    <span>Para:</span> <strong id="preview-destinatario">Destinatario</strong>
                  </div>
                  <div class="preview-text" id="preview-mensaje">Tu mensaje aparecera aqui...</div>
                </div>

                <div class="preview-footer">
                  <span>Galicia</span>
                  <span>2026</span>
                </div>
              </div>
            </div>

            <p class="preview-caption">Asi se vera tu postal</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    const form = document.getElementById('postal-form') as HTMLFormElement;
    const previewImg = document.getElementById('preview-img') as HTMLImageElement;
    const previewEmisor = document.getElementById('preview-emisor') as HTMLElement;
    const previewDestinatario = document.getElementById('preview-destinatario') as HTMLElement;
    const previewMensaje = document.getElementById('preview-mensaje') as HTMLElement;
    const contador = document.getElementById('contador') as HTMLElement;
    const mensajeTextarea = document.getElementById('mensaje') as HTMLTextAreaElement;

    // Update image preview
    document.querySelectorAll('input[name="imagen_postal"]').forEach(radio => {
      radio.addEventListener('change', () => {
        if (previewImg) {
          previewImg.src = radio.getAttribute('data-src') || "";
        }
      });
    });

    // Update text previews
    const emisorInput = document.getElementById('nombre_emisor') as HTMLInputElement;
    if (emisorInput) {
      emisorInput.addEventListener('input', e => {
        const target = e.target as HTMLInputElement;
        if (previewEmisor) previewEmisor.textContent = target.value || 'Tu nombre';
      });
    }

    const destinatarioInput = document.getElementById('nombre_destinatario') as HTMLInputElement;
    if (destinatarioInput) {
      destinatarioInput.addEventListener('input', e => {
        const target = e.target as HTMLInputElement;
        if (previewDestinatario) previewDestinatario.textContent = target.value || 'Destinatario';
      });
    }

    if (mensajeTextarea) {
      mensajeTextarea.addEventListener('input', e => {
        const target = e.target as HTMLTextAreaElement;
        if (previewMensaje) previewMensaje.textContent = target.value || 'Tu mensaje aparecera aqui...';
        if (contador) contador.textContent = String(target.value.length);
      });
    }

    // Form submission
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        if (btn) {
          btn.disabled = true;
          btn.innerHTML = 'Enviando...';
        }

        try {
          const formData = new FormData(form);
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: formData,
          });
          const result = await response.json();

          if (result.success) {
            form.style.display = 'none';
            const exito = document.getElementById('mensaje-exito');
            if (exito) exito.hidden = false;
          } else {
            throw new Error(result.message);
          }
        } catch (error) {
          alert('Error al enviar. Intenta de nuevo.');
          console.error(error);
        } finally {
          if (btn) {
            btn.disabled = false;
            btn.innerHTML = `
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 2L11 13" /><path d="M22 2l-7 20-4-9-9-4 20-7z" />
              </svg> Enviar Postal`;
          }
        }
      });
    }

    // Reset form
    (window as any).resetForm = () => {
      if (form) {
        form.reset();
        form.style.display = 'block';
      }
      const exito = document.getElementById('mensaje-exito');
      if (exito) exito.hidden = true;
      if (previewImg) previewImg.src = '/images/seccion-arcos.jpg';
      if (previewEmisor) previewEmisor.textContent = 'Tu nombre';
      if (previewDestinatario) previewDestinatario.textContent = 'Destinatario';
      if (previewMensaje) previewMensaje.textContent = 'Tu mensaje aparecera aqui...';
      if (contador) contador.textContent = '0';
    };
  </script>

  <style>
    .postal-page {
      /* Usando variables globales del Layout */
    }

    /* Hero */
    .postal-hero {
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-deep) 100%);
      color: white;
      padding: 4rem 1rem 3rem;
      text-align: center;
    }

    .postal-hero-content {
      max-width: 600px;
      margin: 0 auto;
    }

    .hero-eyebrow {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      opacity: 0.9;
      margin-bottom: 0.5rem;
    }

    .postal-hero h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      margin: 0 0 1rem;
      color: white;
    }

    .postal-hero p {
      font-size: 1.1rem;
      opacity: 0.9;
      margin: 0;
    }

    /* Main section */
    .postal-main {
      padding: 3rem 1rem;
      background: var(--color-bg);
    }

    .postal-container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .section-label {
      display: block;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--color-accent-text);
      margin-bottom: 0.5rem;
    }

    .section-header h2 {
      font-size: clamp(1.5rem, 4vw, 2rem);
      color: var(--color-primary);
      margin: 0;
    }

    /* Grid */
    .postal-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: start;
    }

    /* Form panel */
    .form-panel {
      background: var(--color-surface);
      border-radius: 16px;
      padding: 2rem;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }

    .form-section {
      border: none;
      padding: 0;
      margin: 0 0 1.5rem;
    }

    .form-section legend {
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-primary);
      margin-bottom: 0.75rem;
      padding: 0;
    }

    /* Image selector */
    .imagenes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }

    .imagen-option {
      cursor: pointer;
      position: relative;
    }

    .imagen-option input {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
    }

    .imagen-card {
      position: relative;
      border-radius: 10px;
      overflow: hidden;
      border: 3px solid transparent;
      transition: all 0.2s;
    }

    .imagen-card img {
      width: 100%;
      height: 100px;
      object-fit: cover;
      display: block;
    }

    .imagen-titulo {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 0.4rem;
      background: linear-gradient(transparent, rgba(0,0,0,0.7));
      color: white;
      font-size: 0.75rem;
      text-align: center;
    }

    .imagen-option input:checked + .imagen-card {
      border-color: var(--color-accent);
      box-shadow: 0 0 0 3px rgba(21, 152, 149, 0.2);
    }

    .imagen-option input:focus-visible + .imagen-card {
      outline: 3px solid var(--color-accent);
      outline-offset: 2px;
    }

    /* Form fields */
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .form-group {
      margin-bottom: 0.75rem;
    }

    .form-group label {
      display: block;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--color-text);
      margin-bottom: 0.35rem;
    }

    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 0.75rem;
      border: 2px solid #e0e0e0;
      border-radius: 8px;
      font-size: 1rem;
      font-family: inherit;
      background: white;
      color: var(--color-text);
      transition: border-color 0.2s;
    }

    .form-group input:focus,
    .form-group textarea:focus {
      outline: 3px solid var(--color-accent-text);
      outline-offset: 1px;
      border-color: var(--color-accent-text);
    }

    .form-group input:invalid:not(:placeholder-shown),
    .form-group textarea:invalid:not(:placeholder-shown) {
      border-color: #dc3545;
    }

    .form-group input:invalid:not(:placeholder-shown):focus,
    .form-group textarea:invalid:not(:placeholder-shown):focus {
      outline-color: #dc3545;
      border-color: #dc3545;
    }

    .contador {
      text-align: right;
      font-size: 0.8rem;
      color: var(--color-text-secondary);
      margin: 0.25rem 0 0;
    }

    /* Buttons */
    .btn-enviar {
      width: 100%;
      padding: 1rem;
      background: linear-gradient(135deg, var(--color-accent-text), var(--color-primary));
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 1.1rem;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .btn-enviar:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(21, 152, 149, 0.3);
    }

    .btn-enviar:disabled {
      opacity: 0.7;
      cursor: not-allowed;
    }

    .btn-secondary {
      padding: 0.75rem 1.5rem;
      background: white;
      color: var(--color-primary);
      border: 2px solid var(--color-primary);
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-secondary:hover {
      background: var(--color-primary);
      color: white;
    }

    /* Success message */
    .mensaje-exito {
      text-align: center;
      padding: 2rem;
    }

    .exito-icon {
      width: 60px;
      height: 60px;
      margin: 0 auto 1rem;
      background: #2ecc71;
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      font-weight: bold;
    }

    .mensaje-exito h3 {
      color: var(--color-primary);
      margin: 0 0 0.5rem;
    }

    .mensaje-exito p {
      color: var(--color-text-secondary);
      margin: 0 0 1rem;
    }

    /* Preview panel */
    .preview-panel {
      position: sticky;
      top: 100px;
    }

    .preview-card {
      background: white;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(0,0,0,0.15);
      transform: rotate(-1deg);
      transition: transform 0.3s;
    }

    .preview-card:hover {
      transform: rotate(0deg);
    }

    .preview-header {
      padding: 0.75rem 1rem;
      background: linear-gradient(135deg, var(--color-primary), var(--color-accent-text));
      color: white;
    }

    .preview-logo {
      font-size: 0.85rem;
      font-weight: 600;
    }

    .preview-image {
      height: 200px;
      overflow: hidden;
    }

    .preview-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .preview-body {
      padding: 1.25rem;
    }

    .preview-location {
      margin-bottom: 1rem;
      padding-bottom: 1rem;
      border-bottom: 2px dashed rgba(21, 152, 149, 0.3);
    }

    .preview-location h3 {
      font-size: 1.1rem;
      color: var(--color-primary);
      margin: 0 0 0.25rem;
    }

    .preview-location p {
      font-size: 0.85rem;
      color: var(--color-text-secondary);
      margin: 0;
    }

    .preview-message {
      margin-bottom: 1rem;
    }

    .preview-from,
    .preview-to {
      font-size: 0.85rem;
      margin-bottom: 0.35rem;
    }

    .preview-from span,
    .preview-to span {
      color: var(--color-text-secondary);
    }

    .preview-text {
      margin-top: 0.75rem;
      padding: 0.75rem;
      background: rgba(21, 152, 149, 0.05);
      border-radius: 8px;
      font-style: italic;
      font-size: 0.9rem;
      color: var(--color-text);
      min-height: 60px;
    }

    .preview-footer {
      display: flex;
      justify-content: space-between;
      padding-top: 0.75rem;
      border-top: 1px solid #eee;
      font-size: 0.8rem;
      color: var(--color-text-secondary);
    }

    .preview-caption {
      text-align: center;
      margin-top: 1rem;
      color: var(--color-text-secondary);
      font-size: 0.9rem;
      font-style: italic;
    }

    /* Responsive */
    @media (max-width: 900px) {
      .postal-grid {
        grid-template-columns: 1fr;
      }

      .preview-panel {
        position: static;
        order: -1;
      }

      .preview-card {
        transform: none;
        max-width: 400px;
        margin: 0 auto;
      }
    }

    @media (max-width: 600px) {
      .imagenes-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .form-row {
        grid-template-columns: 1fr;
      }

      .form-panel {
        padding: 1.25rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .preview-card {
        transform: none;
      }
    }
  </style>
</Layout>