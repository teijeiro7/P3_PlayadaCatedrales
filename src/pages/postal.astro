---
import Layout from '../layouts/Layout.astro';

const tarjetas = [
  { id: 'catedrales', src: '/images/tarjeta-catedrales.jpg', alt: 'Postal de los arcos de la Playa de las Catedrales' },
  { id: 'atardecer', src: '/images/tarjeta-atardecer.jpg', alt: 'Postal del atardecer en la playa' },
  { id: 'arena', src: '/images/tarjeta-arena.jpg', alt: 'Postal de la arena dorada' }
];

let mensajeEnviado = false;

if (Astro.request.method === 'POST') {
  mensajeEnviado = true;
}
---

<Layout title="Enviar Postal" description="Envía una postal digital de la Playa de las Catedrales a tus seres queridos">
  <div class="container">
    <h1>Enviar una Postal</h1>
    <p>Elige una imagen y escribe un mensaje personalizado para enviar una postal digital de la Praia das Catedrais.</p>
    
    {mensajeEnviado ? (
      <div class="mensaje-exito" role="alert">
        <h2>¡Postal Enviada!</h2>
        <p>Tu postal ha sido enviada correctamente. (Simulacion)</p>
        <a href="/postal">Enviar otra postal</a>
      </div>
    ) : (
      <form method="POST" action="/postal" aria-label="Formulario para enviar una postal">
        <fieldset>
          <legend>Elige una imagen para tu postal</legend>
          <div class="tarjetas-grid" role="list">
            {tarjetas.map((tarjeta) => (
              <label class="tarjeta-option">
                <input type="radio" name="tarjeta" value={tarjeta.id} required>
                <img src={tarjeta.src} alt={tarjeta.alt}>
              </label>
            ))}
          </div>
        </fieldset>

        <div class="form-group">
          <label for="nombre">Tu nombre <span aria-hidden="true">*</span></label>
          <input type="text" id="nombre" name="nombre" required autocomplete="name" placeholder="Escribe tu nombre">
        </div>

        <div class="form-group">
          <label for="email">Tu correo electronico <span aria-hidden="true">*</span></label>
          <input type="email" id="email" name="email" required autocomplete="email" placeholder="tu@email.com">
        </div>

        <div class="form-group">
          <label for="destinatario">Nombre del destinatario <span aria-hidden="true">*</span></label>
          <input type="text" id="destinatario" name="destinatario" required placeholder="Nombre de quien recibe la postal">
        </div>

        <div class="form-group">
          <label for="email-destinatario">Correo del destinatario <span aria-hidden="true">*</span></label>
          <input type="email" id="email-destinatario" name="email-destinatario" required placeholder="destinatario@email.com">
        </div>

        <div class="form-group">
          <label for="mensaje">Mensaje <span aria-hidden="true">*</span></label>
          <textarea id="mensaje" name="mensaje" required rows="4" maxlength="200" placeholder="Escribe tu mensaje (maximo 200 caracteres)"></textarea>
          <p id="ayuda-caracteres" class="help-text">Maximo 200 caracteres</p>
        </div>

        <button type="submit">Enviar Postal</button>
      </form>
    )}
  </div>
</Layout>

<style>
  .container { max-width: 600px; margin: 0 auto; padding: 0 1rem; }
  fieldset { border: none; padding: 0; margin: 0; }
  legend { font-weight: bold; font-size: 1.1rem; margin-bottom: 1rem; color: var(--color-primary); }
  .tarjetas-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .tarjeta-option { cursor: pointer; }
  .tarjeta-option input { position: absolute; opacity: 0; }
  .tarjeta-option img { width: 100%; height: auto; border-radius: 8px; border: 3px solid transparent; transition: border-color 0.2s; }
  .tarjeta-option input:checked + img { border-color: var(--color-accent); }
  .tarjeta-option input:focus + img { outline: 3px solid var(--color-accent); outline-offset: 2px; }
  .form-group { margin-bottom: 1.5rem; }
  label { display: block; font-weight: bold; margin-bottom: 0.5rem; }
  input, textarea { width: 100%; padding: 0.75rem; border: 2px solid #ddd; border-radius: 8px; font-size: 1rem; font-family: inherit; }
  input:focus, textarea:focus { outline: 3px solid var(--color-accent); outline-offset: 2px; border-color: var(--color-accent); }
  input:user-invalid, textarea:user-invalid { border-color: #d00; }
  .help-text { font-size: 0.85rem; color: #666; margin-top: 0.25rem; }
  button { background: var(--color-accent); color: white; border: none; padding: 1rem 2rem; font-size: 1rem; font-weight: bold; border-radius: 8px; cursor: pointer; transition: background 0.2s; }
  button:hover, button:focus { background: var(--color-primary); }
  .mensaje-exito { background: #d4edda; padding: 2rem; border-radius: 8px; text-align: center; }
  .mensaje-exito h2 { color: #155724; }
  .mensaje-exito a { display: inline-block; margin-top: 1rem; color: var(--color-primary); }
  @media (max-width: 500px) {
    .tarjetas-grid { grid-template-columns: 1fr; }
  }
</style>