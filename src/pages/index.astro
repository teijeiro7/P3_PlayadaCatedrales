---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Inicio"
  description="Playa de las Catedrales - Monumento Natural en Ribadeo, Lugo. Descubre la Praia das Catedrais, una obra de arte esculpida por el mar."
  variant="home"
>
  <section class="hero" id="inicio" aria-labelledby="hero-title">
    <video
      autoplay
      muted
      loop
      playsinline
      class="hero-video"
      aria-hidden="true"
    >
      <source src="/videos/video1.mp4" type="video/mp4" />
      <track kind="descriptions" label="Descripciones en español" srclang="es" src="/captions/video1-descriptions.vtt" default />
    </video>
    <div class="hero-overlay"></div>
    <canvas id="water-canvas" aria-hidden="true"></canvas>
    <div class="hero-content">
      <h1 id="hero-title" class="hero-title">La Catedral del Mar</h1>
      <p class="hero-subtitle">
        Arcos de piedra de 30 metros esculpidos por el Atlantico en Ribadeo,
        Lugo. Una arquitectura sagrada nacida del agua y el tiempo.
      </p>
      <div class="hero-cta">
        <a href="/galeria" class="btn-hero btn-hero-primary">Ver Galeria</a>
        <a href="/postal" class="btn-hero btn-hero-secondary">Enviar Postal</a>
      </div>
    </div>
    <div class="scroll-indicator" aria-hidden="true">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
        <path
          d="M12 5v14m0 0l-6-6m6 6l6-6"
          stroke="white"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </div>
    <button
      id="video-pause-btn"
      class="video-pause-btn"
      aria-label="Pausar video de fondo"
      aria-pressed="false"
      type="button">
      <svg id="pause-icon-pause" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect x="6" y="4" width="4" height="16" fill="white"></rect>
        <rect x="14" y="4" width="4" height="16" fill="white"></rect>
      </svg>
      <svg id="pause-icon-play" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="display: none;">
        <path d="M5 3l14 9-14 9V3z" fill="white"></path>
      </svg>
    </button>
  </section>

  <section class="stats-bar" aria-label="Estadisticas">
    <div class="stats-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path
          d="M0,60 Q180,0 360,60 T720,60 T1080,60 T1440,60 L1440,120 L0,120 Z"
          fill="rgba(255,255,255,0.05)"></path>
      </svg>
    </div>
    <div class="stats-grid">
      <div class="stat-item">
        <span class="stat-number" data-target="30">0</span><span
          class="stat-unit">m</span
        >
        <span class="stat-label">Arcos de altura</span>
      </div>
      <div class="stat-item">
        <span class="stat-number" data-target="15">0</span><span
          class="stat-unit">km</span
        >
        <span class="stat-label">Costa protegida</span>
      </div>
      <div class="stat-item">
        <span class="stat-number" data-target="2">0</span><span
          class="stat-unit">x</span
        >
        <span class="stat-label">Ciclos de marea diarios</span>
      </div>
    </div>
  </section>

  <section class="about" id="historia" aria-labelledby="about-title">
    <div class="container">
      <div class="about-grid">
        <div class="about-text reveal">
          <span class="section-label">HISTORIA Y NATURALEZA</span>
          <h2 id="about-title" class="section-title">
            Arquitectura Natural de Piedra Eterna
          </h2>
          <p>
            Durante milenios, el oceano Cantabrico ha tallado con paciencia
            infinita las pizarras y cuarcitas de la costa lucense. El resultado
            es un santuario geologico donde los arcos de piedra de mas de 30
            metros de altura desafian la gravedad.
          </p>
          <p>
            Ubicada en el municipio de Ribadeo, la Playa de Aguas Santas
            &mdash;su nombre original&mdash; se transforma radicalmente con las
            mareas. En bajamar, el suelo marino se convierte en una catedral
            gotica al aire libre, revelando cuevas, pasadizos y los famosos
            arcos que le dan su apodo mundialmente conocido.
          </p>
          <div class="about-badge">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <span>Monumento Natural declarado por la Xunta de Galicia.</span>
          </div>
        </div>
        <div class="about-visual reveal">
          <div class="about-image-frame">
            <div class="about-image-bg">
              <img
                src="/images/galeria-panoramica.jpg"
                alt="Vista panorámica de la playa"
              />
            </div>
          </div>
          <div class="about-floating-card">
            <span class="about-floating-number">Milenios</span>
            <span class="about-floating-label">De erosion marina</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="gallery-mosaic" id="galeria" aria-labelledby="gallery-title">
    <div class="container">
      <div class="gallery-header">
        <h2 id="gallery-title" class="section-title">
          Galeria de las Maravillas
        </h2>
        <div class="gallery-divider"></div>
      </div>
      <div class="mosaic-grid">
        <article
          class="mosaic-item mosaic-item-hero reveal"
          aria-labelledby="mosaic-arcos"
        >
          <div class="mosaic-bg mosaic-bg-arcos"></div>
          <div class="mosaic-overlay"></div>
          <div class="mosaic-content">
            <h3 id="mosaic-arcos">Los Arcos</h3>
            <p>La estructura emblematica de 30 metros de altura.</p>
          </div>
        </article>
        <article class="mosaic-item reveal" aria-labelledby="mosaic-cuevas">
          <div class="mosaic-bg mosaic-bg-cuevas"></div>
          <div class="mosaic-overlay"></div>
          <div class="mosaic-content">
            <h3 id="mosaic-cuevas">Las Cuevas</h3>
            <p>Santuarios sombrios donde el mar susurra.</p>
          </div>
        </article>
        <article class="mosaic-item reveal" aria-labelledby="mosaic-fauna">
          <div class="mosaic-bg mosaic-bg-fauna"></div>
          <div class="mosaic-overlay"></div>
          <div class="mosaic-content">
            <span class="mosaic-chip">BIODIVERSIDAD</span>
            <h3 id="mosaic-fauna">Vida en la Roca</h3>
          </div>
        </article>
        <article class="mosaic-item reveal" aria-labelledby="mosaic-amanecer">
          <div class="mosaic-bg mosaic-bg-amanecer"></div>
          <div class="mosaic-overlay"></div>
          <div class="mosaic-content">
            <span class="mosaic-chip">MOMENTOS</span>
            <h3 id="mosaic-amanecer">Primeras Luces</h3>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="destacados" aria-labelledby="destacados-title">
    <div class="container">
      <h2 id="destacados-title" class="section-title section-title-centered">
        Lugares Sagrados
      </h2>
      <div class="destacados-grid">
        <article class="card card-arcos reveal">
          <div class="card-header">
            <svg
              width="48"
              height="48"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M2 20L12 4l10 16"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M6 16l6-8 6 8"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <div class="card-body">
            <h3>Arcos Monumentales</h3>
            <p>
              Sucesion de contrafuertes naturales de hasta 30 metros que
              recuerdan a una nave catedralicia.
            </p>
          </div>
        </article>
        <article class="card card-mareas reveal">
          <div class="card-header">
            <svg
              width="48"
              height="48"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"
                stroke="currentColor"
                stroke-width="1.5"></path>
              <path
                d="M12 6v6l4 2"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"></path>
            </svg>
          </div>
          <div class="card-body">
            <h3>Mareas Vivas</h3>
            <p>
              El espectaculo de la retirada del mar que ocurre dos veces al dia,
              revelando un mundo oculto.
            </p>
          </div>
        </article>
        <article class="card card-natura reveal">
          <div class="card-header">
            <svg
              width="48"
              height="48"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M9 22V12h6v10"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <div class="card-body">
            <h3>Red Natura 2000</h3>
            <p>
              Un ecosistema protegido de alto valor biologico y geologico en la
              Marina Lucense.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="tide-timeline" aria-labelledby="tide-title">
    <div class="container">
      <div class="tide-header">
        <h2 id="tide-title" class="section-title section-title-centered">
          El Ritmo del Oceano
        </h2>
        <p class="section-subtitle">
          El tiempo aqui lo marca la luna, no el reloj.
        </p>
      </div>
      <div class="timeline" role="list">
        <div class="timeline-line" aria-hidden="true"></div>
        <div class="timeline-item reveal" role="listitem">
          <div class="timeline-dot">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <circle
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="2"
                fill="currentColor"
                fill-opacity="0.2"></circle>
              <path
                d="M12 8v5l3 3"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"></path>
            </svg>
          </div>
          <h3>Pleamar</h3>
          <span class="timeline-status">ACCESO CERRADO</span>
        </div>
        <div class="timeline-item reveal" role="listitem">
          <div class="timeline-dot">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M12 5v14m-6-6l6 6 6-6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <h3>Bajando</h3>
          <span class="timeline-status">PREPARACION</span>
        </div>
        <div class="timeline-item timeline-item-active reveal" role="listitem">
          <div class="timeline-dot">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M17 12a5 5 0 01-10 0m10 0a5 5 0 00-10 0m10 0h-3m-7 0H4"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"></path>
            </svg>
          </div>
          <h3>Bajamar</h3>
          <span class="timeline-status timeline-status-active"
            >HORA DE VISITA</span
          >
        </div>
        <div class="timeline-item reveal" role="listitem">
          <div class="timeline-dot">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M12 19V5m6 6l-6-6-6 6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <h3>Subiendo</h3>
          <span class="timeline-status">RETIRADA</span>
        </div>
      </div>
    </div>
  </section>

  <section class="quote-section" aria-label="Cita inspiradora">
    <div class="quote-bg"></div>
    <div class="quote-content">
      <svg
        class="quote-icon"
        width="64"
        height="64"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"
          fill="currentColor"></path>
        <path
          d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"
          fill="currentColor"></path>
      </svg>
      <blockquote>
        &ldquo;No es solo una playa, es el susurro de la tierra convertido en
        arquitectura sagrada por el abrazo del mar.&rdquo;
      </blockquote>
      <cite>&mdash; Cronicas del Cantabrico</cite>
    </div>
  </section>

  <section class="visit-info" id="visitar" aria-labelledby="info-title">
    <div class="container">
      <h2 id="info-title" class="section-title section-title-centered">
        Planifica tu Visita
      </h2>
      <div class="info-grid">
        <article class="info-card reveal" aria-labelledby="info-mareas">
          <div class="info-icon">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <circle
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="2"></circle>
              <path
                d="M12 6v6l4 2"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"></path>
            </svg>
          </div>
          <h3 id="info-mareas">Horario de Mareas</h3>
          <p>
            El acceso a los arcos solo es posible durante la bajamar. Consulta
            la tabla oficial antes de tu llegada.
          </p>
          <span class="info-tide-badge">
            <span class="info-dot"></span>
            Estado actual: Bajamar
          </span>
        </article>
        <article class="info-card reveal" aria-labelledby="info-reserva">
          <div class="info-icon">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <rect
                x="3"
                y="11"
                width="18"
                height="11"
                rx="2"
                stroke="currentColor"
                stroke-width="2"></rect>
              <path
                d="M7 11V7a5 5 0 0110 0v4"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"></path>
            </svg>
          </div>
          <h3 id="info-reserva">Reserva Obligatoria</h3>
          <p>
            Del 1 de julio al 30 de septiembre y Semana Santa se requiere
            reserva online gratuita.
          </p>
          <a
            href="https://ascatedrais.xunta.es/"
            class="info-cta-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Solicitar pase gratuito en el sitio oficial de la Xunta (se abre en nueva pestaña)">Solicitar pase gratuito</a
          >
        </article>
        <article class="info-card reveal" aria-labelledby="info-llegar">
          <div class="info-icon">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"
                stroke="currentColor"
                stroke-width="2"></path>
              <circle
                cx="12"
                cy="9"
                r="2.5"
                stroke="currentColor"
                stroke-width="2"></circle>
            </svg>
          </div>
          <h3 id="info-llegar">Como Llegar</h3>
          <p>
            A 10 km al oeste de Ribadeo por la N-634 o autovia A-8. Aparcamiento
            gratuito senalizado.
          </p>
        </article>
        <article class="info-card reveal" aria-labelledby="info-entrada">
          <div class="info-icon">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"></path>
              <circle
                cx="12"
                cy="7"
                r="4"
                stroke="currentColor"
                stroke-width="2"></circle>
            </svg>
          </div>
          <h3 id="info-entrada">Entrada Gratuita</h3>
          <p>
            Acceso gratuito todo el año. Solo necesitas reservar en temporada
            alta para proteger el entorno.
          </p>
        </article>
      </div>
      <div class="info-footer">
        <a href="/visitar" class="btn-hero btn-hero-primary"
          >Mas informacion practica</a
        >
      </div>
    </div>
  </section>

  <section class="map-section" aria-label="Ubicacion en el mapa">
    <div class="map-bg" aria-hidden="true"></div>
    <div class="map-card">
      <h3>Ubicacion</h3>
      <p>Carretera de la Costa, s/n<br />27700 Ribadeo, Lugo, Espana</p>
      <div class="map-contact">
        <span>
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          +34 982 128 689
        </span>
        <span>
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M22 6l-10 7L2 6"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          turismo@ribadeo.gal
        </span>
      </div>
    </div>
  </section>
</Layout>

<script>
  import * as THREE from "three";

  const waterCanvas = document.getElementById(
    "water-canvas",
  ) as HTMLCanvasElement;
  let waterMesh: THREE.Mesh,
    scene: THREE.Scene,
    camera: THREE.PerspectiveCamera,
    renderer: THREE.WebGLRenderer | null = null;
  let mouseX = 0,
    mouseY = 0;

  if (waterCanvas) {
    const hero = document.querySelector(".hero") as HTMLElement;

    const initWater = () => {
      scene = new THREE.Scene();
      camera = new THREE.PerspectiveCamera(
        75,
        waterCanvas.clientWidth / waterCanvas.clientHeight,
        0.1,
        1000,
      );
      try {
        renderer = new THREE.WebGLRenderer({
          canvas: waterCanvas,
          alpha: true,
          antialias: true,
          powerPreference: "high-performance",
        });
        renderer.setSize(waterCanvas.clientWidth, waterCanvas.clientHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      } catch (error) {
        console.warn("WebGL renderer creation failed:", error);
        waterCanvas.style.display = "none";
        return;
      }

      const geometry = new THREE.PlaneGeometry(20, 8, 128, 64);
      const material = new THREE.ShaderMaterial({
        uniforms: {
          uTime: { value: 0 },
          uColor1: { value: new THREE.Color("#57c5b6") },
          uColor2: { value: new THREE.Color("#1a5f7a") },
          uMouse: { value: new THREE.Vector2(0, 0) },
        },
        vertexShader: `
          uniform float uTime;
          uniform vec2 uMouse;
          varying vec2 vUv;
          varying float vElevation;
          void main() {
            vUv = uv;
            vec3 pos = position;
            float wave1 = sin(pos.x * 2.0 + uTime * 0.8) * 0.15;
            float wave2 = sin(pos.x * 3.5 + pos.y * 2.0 + uTime * 1.2) * 0.1;
            float wave3 = sin(pos.x * 1.5 - uTime * 0.6 + pos.y * 1.5) * 0.05;
            float mouseWave = sin(pos.x * 4.0 + uMouse.x * 2.0 + pos.y * 3.0 + uMouse.y * 2.0) * 0.08;
            pos.z += wave1 + wave2 + wave3 + mouseWave;
            vElevation = pos.z;
            gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
          }
        `,
        fragmentShader: `
          uniform vec3 uColor1;
          uniform vec3 uColor2;
          uniform float uTime;
          varying vec2 vUv;
          varying float vElevation;
          void main() {
            float mixFactor = (vElevation * 2.0 + 0.5) * 0.5 + 0.3;
            vec3 color = mix(uColor1, uColor2, mixFactor);
            float alpha = 0.35 + sin(vUv.x * 20.0 + uTime) * 0.1;
            alpha = clamp(alpha, 0.15, 0.4);
            gl_FragColor = vec4(color, alpha);
          }
        `,
        transparent: true,
        side: THREE.DoubleSide,
      });

      waterMesh = new THREE.Mesh(geometry, material);
      waterMesh.position.set(0, 0.5, 0);
      waterMesh.rotation.x = -0.1;
      scene.add(waterMesh);

      camera.position.set(0, 0, 6);

      const animate = () => {
        requestAnimationFrame(animate);
        material.uniforms.uTime.value += 0.016;
        material.uniforms.uMouse.value.x +=
          (mouseX - material.uniforms.uMouse.value.x) * 0.05;
        material.uniforms.uMouse.value.y +=
          (mouseY - material.uniforms.uMouse.value.y) * 0.05;
        if (renderer) renderer.render(scene, camera);
      };
      animate();
    };

    initWater();

    if (hero) {
      hero.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = hero.getBoundingClientRect();
        mouseX = (e.clientX / rect.width) * 2 - 1;
        mouseY = (e.clientY / rect.height) * 2 - 1;
      });
    }

    const resizeWater = () => {
      const w = waterCanvas.clientWidth;
      const h = waterCanvas.clientHeight;
      if (!renderer) return;
      renderer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    };

    window.addEventListener("resize", resizeWater);
  }

  const revealElements = document.querySelectorAll(".reveal");
  const statNumbers = document.querySelectorAll(".stat-number");
  let statsCounted = false;

  const observerOptions = { threshold: 0.15, rootMargin: "0px 0px -50px 0px" };

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("revealed");
        revealObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  revealElements.forEach((el) => revealObserver.observe(el));

  const statsObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !statsCounted) {
          statsCounted = true;
          statNumbers.forEach((counter) => {
            const htmlCounter = counter as HTMLElement;
            const target = parseInt(htmlCounter.dataset.target || "0");
            const duration = 2000;
            const start = performance.now();
            const step = (timestamp: number) => {
              const progress = Math.min((timestamp - start) / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              htmlCounter.textContent = String(Math.floor(eased * target));
              if (progress < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
          });
          statsObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.5 },
  );

  const statsBar = document.querySelector(".stats-bar");
  if (statsBar) statsObserver.observe(statsBar);

  const videoPauseBtn = document.getElementById(
    "video-pause-btn",
  ) as HTMLButtonElement;
  const heroVideo = document.querySelector(".hero-video") as HTMLVideoElement;
  const pauseIcons = document.querySelectorAll<SVGElement>(
    "#pause-icon-pause, #pause-icon-pause2",
  );
  const playIcon = document.querySelector<SVGElement>("#pause-icon-play");

  if (heroVideo) {
    heroVideo.play().catch(() => {
      console.log("Autoplay blocked, waiting for interaction");
    });
  }

  if (videoPauseBtn && heroVideo) {
    videoPauseBtn.addEventListener("click", () => {
      const paused = heroVideo.paused;
      if (paused) {
        heroVideo.play();
        videoPauseBtn.setAttribute("aria-label", "Pausar video de fondo");
        videoPauseBtn.setAttribute("aria-pressed", "false");
        pauseIcons.forEach((el) => (el.style.display = ""));
        if (playIcon) playIcon.style.display = "none";
      } else {
        heroVideo.pause();
        videoPauseBtn.setAttribute("aria-label", "Reanudar video de fondo");
        videoPauseBtn.setAttribute("aria-pressed", "true");
        pauseIcons.forEach((el) => (el.style.display = "none"));
        if (playIcon) playIcon.style.display = "";
      }
    });
  }
</script>

