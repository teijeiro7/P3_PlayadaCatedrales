---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Como Visitar"
  description="Informacion practica para visitar la Playa de las Catedrales: horarios, reservas, como llegar, mareas y recomendaciones."
  variant="home"
>
  <section class="hero-parallax" aria-labelledby="hero-title">
    <div class="hero-parallax-bg visitar-hero" aria-hidden="true"></div>
    <div class="hero-parallax-overlay"></div>
    <div class="hero-parallax-content">
      <span class="hero-eyebrow">PLANIFICA TU VISITA</span>
      <h1 id="hero-title" class="hero-title">
        Como Visitar la<br />Praia das Catedrais
      </h1>
      <p class="hero-subtitle">
        Todo lo que necesitas saber para una experiencia inolvidable en este
        Monumento Natural de Galicia.
      </p>
      <div class="hero-scroll-hint" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path
            d="M12 5v14m0 0l-6-6m6 6l6-6"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
      </div>
    </div>
  </section>

  <section class="info-cards" aria-label="Informacion rapida">
    <div class="info-grid">
      <div class="info-card reveal">
        <div class="info-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h3>Horario de Visita</h3>
        <p>Acceso permitido solo durante la marea baja. Consulta los horarios antes de tu visita.</p>
      </div>
      <div class="info-card reveal">
        <div class="info-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <h3>Ubicacion</h3>
        <p>Parroquia de Devesa, Ribadeo, Lugo. A 86 km de Lugo capital.</p>
      </div>
      <div class="info-card reveal">
        <div class="info-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <h3>Reserva Obligatoria</h3>
        <p>De Semana Santa a septiembre. Reserva con 3-5 dias de antelacion.</p>
      </div>
    </div>
  </section>

  <section class="reservas-section" aria-labelledby="reservas-title">
    <div class="container">
      <div class="reservas-grid">
        <div class="reservas-content reveal">
          <span class="section-label">RESERVAS</span>
          <h2 id="reservas-title" class="section-title">
            Cuando Necesitas Autorizacion
          </h2>
          <p>
            El acceso a la playa es <strong>gratuito</strong>, pero durante
            determinadas epocas del ano se requiere
            <strong>autorizacion previa</strong> para gestionar el aforo y
            proteger el espacio natural.
          </p>
          <div class="temporadas">
            <div class="temporada alta">
              <span class="temporada-badge">ALTA</span>
              <h4>Semana Santa</h4>
              <p>Autorizacion obligatoria. Reserva con antelacion.</p>
            </div>
            <div class="temporada alta">
              <span class="temporada-badge">ALTA</span>
              <h4>1 julio - 30 septiembre</h4>
              <p>Autorizacion obligatoria. Maximo 4.812 visitantes/dia.</p>
            </div>
            <div class="temporada baja">
              <span class="temporada-badge">BAJA</span>
              <h4>Resto del ano</h4>
              <p>Acceso libre sin reserva previa.</p>
            </div>
          </div>
          <a
            href="https://ascatedrais.xunta.gal"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Reservar Entrada
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        </div>
        <div class="reservas-image reveal">
          <img
            src="/images/playa-general.jpg"
            alt="Vista general de la Playa de las Catedrales con visitantes"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="mapa-section" aria-labelledby="mapa-title">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">UBICACION</span>
        <h2 id="mapa-title" class="section-title">Como Llegar</h2>
        <p class="section-subtitle">
          Playa de As Catedrais, San Miguel de Reinante, Ribadeo, Lugo
        </p>
      </div>

      <div class="mapa-grid">
        <div class="mapa-container reveal">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2906.1234567890123!2d-7.159123456789012!3d43.55123456789012!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd31a1234567890%3A0xabcdef1234567890!2sPlaya%20de%20las%20Catedrales!5e0!3m2!1ses!2ses!4v1704067200000!5m2!1ses!2ses"
            width="100%"
            height="500"
            style="border:0; border-radius: 16px;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mapa de la Playa de las Catedrales"
            aria-label="Mapa interactivo de Google Maps mostrando la ubicacion de la Playa de las Catedrales"
          ></iframe>
        </div>

        <div class="transporte-options">
          <div class="transporte-card reveal">
            <div class="transporte-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 16H9m10 0h3v-3.15a1 1 0 00-.84-.99L16 11l-2.7-3.6a1 1 0 00-.8-.4H5.24a2 2 0 00-1.8 1.1l-.8 1.63A6 6 0 002 12.42V16h2"/>
                <circle cx="6.5" cy="16.5" r="2.5"/>
                <circle cx="16.5" cy="16.5" r="2.5"/>
              </svg>
            </div>
            <h3>En Coche</h3>
            <p>Desde Lugo: 86 km por N-640 y E-70/A-8. Desde A Coruna: 160 km por AP-9 y A-6. Parking gratuito disponible junto a la playa.</p>
            <a
              href="https://www.google.com/maps/dir/?api=1&destination=43.5512,-7.1591"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary"
            >
              Como Llegar desde mi Ubicacion
            </a>
          </div>

          <div class="transporte-card reveal">
            <div class="transporte-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="6" width="18" height="12" rx="2"/>
                <path d="M6 18v2"/>
                <path d="M18 18v2"/>
                <path d="M6 10h12"/>
                <path d="M9 14h6"/>
              </svg>
            </div>
            <h3>En Autobus</h3>
            <p>Lineas regulares desde Lugo, A Coruna o Santiago hasta Ribadeo. Desde Ribadeo: taxi o transfer hasta la playa (5 km).</p>
          </div>

          <div class="transporte-card reveal">
            <div class="transporte-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
            <h3>En Tren</h3>
            <p>FEVE (Ferrocarril de Via Estrecha) desde Oviedo o Ferrol hasta Ribadeo. Conexion con autobus local hasta la playa.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mareas-section" aria-labelledby="mareas-title">
    <div class="container">
      <div class="mareas-grid">
        <div class="mareas-image reveal">
          <img
            src="/images/galeria-mareas-01.jpg"
            alt="Formaciones rocosas reveladas durante la marea baja"
            loading="lazy"
          />
        </div>
        <div class="mareas-content reveal">
          <span class="section-label">MAREAS</span>
          <h2 id="mareas-title" class="section-title">
            Consulta el Horario de Mareas
          </h2>
          <p>
            El acceso a los arcos y formaciones rocosas
            <strong>solo es posible durante la marea baja</strong>. El resto del
            tiempo, gran parte del arenal queda cubierto por el mar.
          </p>
          <div class="mareas-alert">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <p>
              <strong>Importante:</strong> El horario de marea baja cambia
              diariamente. Consultalo siempre antes de tu visita.
            </p>
          </div>
          <a
            href="https://www.meteogalicia.gal/mareas"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Ver Horario de Mareas
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="recomendaciones-section" aria-labelledby="recomendaciones-title">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">CONSEJOS</span>
        <h2 id="recomendaciones-title" class="section-title">
          Recomendaciones para tu Visita
        </h2>
      </div>

      <div class="recomendaciones-grid">
        <div class="recomendacion-card reveal">
          <span class="recomendacion-num">01</span>
          <h3>Llega con Antelacion</h3>
          <p>
            Acude con al menos 30 minutos de margen respecto al horario de
            marea baja. El aparcamiento puede saturarse en temporada alta.
          </p>
        </div>
        <div class="recomendacion-card reveal">
          <span class="recomendacion-num">02</span>
          <h3>Calzado Adecuado</h3>
          <p>
            El terreno es rocoso y resbaladizo. Utiliza calzado cerrado y
            antideslizante. Las chanclas no son recomendables.
          </p>
        </div>
        <div class="recomendacion-card reveal">
          <span class="recomendacion-num">03</span>
          <h3>Reserva con Tiempo</h3>
          <p>
            En temporada alta, reserva con 3-5 dias de antelacion. Las
            plazas son limitadas a 4.812 visitantes por dia.
          </p>
        </div>
        <div class="recomendacion-card reveal">
          <span class="recomendacion-num">04</span>
          <h3>No Toques las Formaciones</h3>
          <p>
            Las rocas son fragiles. No escales los arcos ni extraigas
            muestras. Respeta las senales y vallas de proteccion.
          </p>
        </div>
        <div class="recomendacion-card reveal">
          <span class="recomendacion-num">05</span>
          <h3>Vigila la Marea</h3>
          <p>
            La marea sube rapidamente. No te alejes de la salida y presta
            atencion a los avisos acusticos.
          </p>
        </div>
        <div class="recomendacion-card reveal">
          <span class="recomendacion-num">06</span>
          <h3>Accesibilidad</h3>
          <p>
            La playa NO es accesible para personas con movilidad reducida.
            Existen miradores adaptados desde los que observar el paisaje.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="cta-title">
    <div class="cta-content reveal">
      <h2 id="cta-title">Preparado para Vivir la Experiencia?</h2>
      <p>
        Reserva tu entrada, consulta las mareas y descubre uno de los
        paisajes mas espectaculares de la costa gallega.
      </p>
      <div class="cta-buttons">
        <a
          href="https://ascatedrais.xunta.gal"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Reservar Ahora
        </a>
        <a href="/postal" class="btn-secondary"> Enviar Postal </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Scroll animations
  const observerOptions = {
    root: null,
    rootMargin: "0px",
    threshold: 0.1,
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("visible");
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>

<style>
  /* Hero Parallax */
  .hero-parallax {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--color-bg);
  }

  .hero-parallax-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    will-change: transform;
  }

  .visitar-hero {
    background-image: url("/images/catedrais-vista-aerea.jpg");
  }

  .hero-parallax-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 35, 66, 0.5) 0%,
      rgba(10, 35, 66, 0.7) 50%,
      rgba(10, 35, 66, 0.9) 100%
    );
  }

  .hero-parallax-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;
    padding: 2rem;
    max-width: 900px;
  }

  .hero-eyebrow {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    text-wrap: balance;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.35rem);
    line-height: 1.6;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  .hero-scroll-hint {
    margin-top: 3rem;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(10px);
    }
  }

  /* Info Cards */
  .info-cards {
    padding: 5rem 1rem;
    background: var(--color-bg);
  }

  .info-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .info-card {
    background: var(--color-surface);
    border-radius: 16px;
    padding: 2.5rem;
    text-align: center;
    border: 1px solid rgba(0, 188, 212, 0.1);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .info-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 188, 212, 0.1);
  }

  .info-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 1.5rem;
    background: linear-gradient(135deg, var(--color-accent), var(--color-primary));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .info-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .info-card p {
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Reservas Section */
  .reservas-section {
    padding: 6rem 1rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, rgba(0, 188, 212, 0.03) 100%);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .reservas-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .section-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--color-text);
    line-height: 1.2;
  }

  .reservas-content p {
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .temporadas {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .temporada {
    padding: 1.25rem;
    border-radius: 12px;
    border-left: 4px solid;
  }

  .temporada.alta {
    background: rgba(231, 76, 60, 0.08);
    border-left-color: #e74c3c;
  }

  .temporada.baja {
    background: rgba(46, 204, 113, 0.08);
    border-left-color: #2ecc71;
  }

  .temporada-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .temporada.alta .temporada-badge {
    background: #e74c3c;
    color: white;
  }

  .temporada.baja .temporada-badge {
    background: #2ecc71;
    color: white;
  }

  .temporada h4 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
    color: var(--color-text);
  }

  .temporada p {
    font-size: 0.9rem;
    margin: 0;
    color: var(--color-text-secondary);
  }

  .reservas-image img {
    width: 100%;
    border-radius: 16px;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
  }

  /* Mapa Section */
  .mapa-section {
    padding: 6rem 1rem;
    background: var(--color-bg);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-subtitle {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    margin-top: 1rem;
  }

  .mapa-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
  }

  .mapa-container iframe {
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  .transporte-options {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .transporte-card {
    background: var(--color-surface);
    padding: 1.75rem;
    border-radius: 16px;
    border: 1px solid rgba(0, 188, 212, 0.1);
    transition: transform 0.3s;
  }

  .transporte-card:hover {
    transform: translateX(5px);
  }

  .transporte-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, var(--color-accent), var(--color-primary));
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    margin-bottom: 1rem;
  }

  .transporte-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .transporte-card p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  /* Mareas Section */
  .mareas-section {
    padding: 6rem 1rem;
    background: linear-gradient(180deg, rgba(0, 188, 212, 0.03) 0%, var(--color-bg) 100%);
  }

  .mareas-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .mareas-image img {
    width: 100%;
    border-radius: 16px;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
  }

  .mareas-content p {
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .mareas-alert {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: rgba(243, 156, 18, 0.1);
    border-left: 4px solid #f39c12;
    border-radius: 0 12px 12px 0;
    margin-bottom: 2rem;
  }

  .mareas-alert svg {
    flex-shrink: 0;
    color: #f39c12;
  }

  .mareas-alert p {
    margin: 0;
    font-size: 0.95rem;
  }

  /* Recomendaciones */
  .recomendaciones-section {
    padding: 6rem 1rem;
    background: var(--color-bg);
  }

  .recomendaciones-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .recomendacion-card {
    background: var(--color-surface);
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid rgba(0, 188, 212, 0.1);
    position: relative;
